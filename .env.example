# 复制为 .env 并填入真实值（本地 `wrangler dev` 与 CLI 入库都读 .env）
OPENROUTER_API_KEY=   # LLM：对话 + embedding，收口 OpenRouter
PADDLE_API_KEY=       # OCR：PaddleOCR-VL 托管 API
TAVILY_API_KEY=       # 联网兜底

# libSQL 数据库
# DB_MODE 不用在这里配——脚本已绑死：
#   连本地：pnpm dev:local / pnpm ingest:local（dev:local 自带 `turso dev`，喂 vector.db，连 http://127.0.0.1:8080）。
#   连线上：pnpm dev / pnpm ingest（默认走下面的 Turso）。
TURSO_DATABASE_URL=   # libsql://<db>-<org>.turso.io
TURSO_AUTH_TOKEN=     # turso db tokens create <db> 生成

# 单管理员鉴权（ADR-0007）
ADMIN_USER=           # 管理员账号
ADMIN_PASSWORD=       # 管理员密码（明文）
SESSION_SECRET=       # cookie 签名密钥（随便一段长随机串，如 openssl rand -hex 32）
