# 复制为 .env 并填入真实值（本地 `pnpm dev` / `pnpm start` 与 CLI 入库 `pnpm ingest` 都读 .env）
OPENROUTER_API_KEY=   # LLM：对话 + embedding，收口 OpenRouter
PADDLE_API_KEY=       # OCR：PaddleOCR-VL 托管 API
TAVILY_API_KEY=       # 联网兜底

# libSQL 数据库（向量 + 会话历史同库）
# 默认不配即可——回退本地文件库 file:./vector.db（已 gitignore）。
VECTOR_DB_URL=        # 可选，libSQL 库地址；不设则用 file:./vector.db
# 如需连远程 Turso，配下面两个（优先于 VECTOR_DB_URL）：
# TURSO_DATABASE_URL= # libsql://<db>-<org>.turso.io
# TURSO_AUTH_TOKEN=   # turso db tokens create <db> 生成

# 单管理员鉴权（ADR-0007）
ADMIN_USER=           # 管理员账号
ADMIN_PASSWORD=       # 管理员密码（明文）
SESSION_SECRET=       # cookie 签名密钥（随便一段长随机串，如 openssl rand -hex 32）
