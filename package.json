{
  "name": "fastrag",
  "version": "0.1.0",
  "description": "防水卷材国标问答知识库",
  "private": true,
  "type": "module",
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ocr": "tsx src/ocr.ts",
    "ask": "tsx src/ask.ts",
    "web": "tsx src/web.ts",
    "ui": "vite --config ui/vite.config.ts",
    "ui:build": "vite build --config ui/vite.config.ts",
    "dev": "concurrently -k -n api,ui -c blue,magenta \"npm:web\" \"npm:ui\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mastra/core": "1.42.0",
    "@mastra/libsql": "1.13.0",
    "@mastra/memory": "^1.20.3",
    "@mastra/rag": "2.2.1",
    "@libsql/client": "0.17.3",
    "@openrouter/ai-sdk-provider": "2.9.1",
    "ai": "6.0.204",
    "dotenv": "^17.0.0",
    "unpdf": "1.6.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
